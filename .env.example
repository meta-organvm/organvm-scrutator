# organvm-scrutator environment configuration
# Source this file: source .env

# === Core Paths ===
export SCRUTATOR_HOME="${HOME}/Workspace/organvm/organvm-scrutator"
export SCRUTATOR_DATA="${SCRUTATOR_HOME}/data"
export SCRUTATOR_INDICES="${SCRUTATOR_DATA}/indices"

# === Workspace Scanning ===
export SCRUTATOR_WORKSPACE_ROOT="${HOME}/Workspace"
export SCRUTATOR_SCAN_REPOS="organvm|4444J99|mcp-servers|intake"
export SCRUTATOR_SCAN_EXCLUDE="contrib--|bench/"

# === Metrics Collection ===
export SCRUTATOR_COLLECT_QUESTIONS=true
export SCRUTATOR_COLLECT_SUGGESTIONS=true
export SCRUTATOR_COLLECT_ATOMS=true

# === Research Pipeline ===
export SCRUTATOR_RESEARCH_MODE="auto"
export SCRUTATOR_INQUIRY_THRESHOLD=3
export SCRUTATOR_PRAXIS_ENDPOINT="${HOME}/Workspace/organvm/praxis-perpetua"

# === Reporting ===
export SCRUTATOR_OUTPUT_FORMAT="markdown"
export SCRUTATOR_DASHBOARD_PORT=8765

# === External Integration ===
export SCRUTATOR_IRF_ENDPOINT="${HOME}/Workspace/organvm/organvm-corpvs-testamentvm/INST-INDEX-RERUM-FACIENDARUM.md"
export SCRUTATOR_GITHUB_ORG="organvm"
export SCRUTATOR_NOTIFY_WEBHOOK=""

# === Session Tracking ===
export SCRUTATOR_SESSION_ID=""
export SCRUTATOR_START_TIME=""

# === Derived (don't override) ===
export SCRUTATOR_RAW_DATA="${SCRUTATOR_DATA}/raw"
export SCRUTATOR_RESEARCH_DATA="${SCRUTATOR_DATA}/research"
export SCRUTATOR_GAPS_FILE="${SCRUTATOR_RESEARCH_DATA}/gaps.jsonl"
export SCRUTATOR_DISPATCH_FILE="${SCRUTATOR_RESEARCH_DATA}/dispatches.jsonl"

# === Aliases ===
alias scrutator-scan='organvm-scrutator scan'
alias scrutator-stats='organvm-scrutator stats'
alias scrutator-gaps='organvm-scrutator gaps'
alias scrutator-dispatch='organvm-scrutator dispatch'
alias scrutator-energy='organvm-scrutator energy'

# === Functions ===
function scrutator-session-start {
    export SCRUTATOR_SESSION_ID="$(date +%Y-%m-%d)-$(whoami)-$(head -c 4 /dev/urandom | xxd -p)"
    export SCRUTATOR_START_TIME=$(date -Iseconds)
    echo "Session started: $SCRUTATOR_SESSION_ID"
}

function scrutator-session-end {
    local session_id="${SCRUTATOR_SESSION_ID:-unknown}"
    local questions="${1:-0}"
    local suggestions="${2:-0}"
    local atoms="${3:-0}"
    local completions="${4:-0}"
    
    # Record energy
    organvm-scrutator energy
    
    echo "Session $session_id recorded"
    echo "Questions: $questions, Suggestions: $suggestions, Atoms: $atoms, Completions: $completions"
}